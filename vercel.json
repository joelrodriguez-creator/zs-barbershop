{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/prototype/index.html" },
    { "source": "/services", "destination": "/prototype/services.html" },
    { "source": "/gallery", "destination": "/prototype/gallery.html" },
    { "source": "/about", "destination": "/prototype/about.html" },
    { "source": "/contact", "destination": "/prototype/contact.html" },
    { "source": "/book", "destination": "/prototype/contact.html" }
  ]
}
