# Claude state — per-machine, never committed
.claude/*
!.claude/settings.json

# OS
.DS_Store
Thumbs.db

# Vercel local
.vercel

# Editor
.vscode/
.idea/

# Node (in case we add a build step later)
node_modules/
npm-debug.log*

# Generated PDF outputs from case-study.html
*.pdf

# Local Playwright traces / snapshots
test-results/
playwright-report/
.playwright-mcp/

# Imagen variant PNGs — keep only the 5 canonical service icons + the picker.
# Variants are easy to regenerate via scripts/gen-icon.mjs ($0.08/batch via Vertex AI Imagen 4 Fast).
assets/generated/icons/*
!assets/generated/icons/haircut.png
!assets/generated/icons/beard-trim.png
!assets/generated/icons/cut-beard.png
!assets/generated/icons/lineup.png
!assets/generated/icons/kids.png
!assets/generated/icons/picker.html

# Nano Banana 2 hero variants — keep only the accepted finals per page.
# Variants are easy to regenerate via the MCP at ~$0.067/1K image.
assets/generated/heroes/*
!assets/generated/heroes/*-final.jpg
!assets/generated/heroes/*-final.png
!assets/generated/heroes/*-final.webp

# Nano Banana 2 default save directory — transient, files are moved to
# assets/generated/heroes/ after each generation.
generated_imgs/

# Lighthouse + Unlighthouse audit outputs — ephemeral, regenerable via the CLI.
.lighthouse*/
.unlighthouse/

# Client showcase PDF — committed at milestones, whitelisted past the *.pdf rule above
!docs/showcase/client-showcase.pdf
